# Environment variables for local development
FLASK_APP=autoapp.py
FLASK_DEBUG=1
FLASK_ENV=development
GUNICORN_WORKERS=1
LOG_LEVEL=debug
LOG_CONTEXT=off
LOG_COMPLETION=on
RECORD_TRAFFIC=off
# Reasoning display mode:
# - none: hide thinking text in Cursor, preserve native reasoning metadata only.
# - mdthinkblocks: experimental Markdown <details> fallback. This can look bad,
#   is new/unstable, and may fail to show thinking consistently.
# - thinkblocks: legacy visible <think>...</think> chat content.
REASONING_DISPLAY_MODE=mdthinkblocks
# Unauthenticated local-only dashboard port. The dashboard binds 127.0.0.1 only.
DASHBOARD_PORT=20130

# Arbitrary API key to protect your service.
SERVICE_API_KEY=change-me

# Provider switches. Root and /azure use Azure; /codex uses Codex.
ENABLE_AZURE=true
ENABLE_CODEX=false

# Mandatory Azure settings
AZURE_BASE_URL=https://change-me.openai.azure.com
AZURE_API_KEY=change-me

# Optional JSON mapping from Cursor-facing model ids to Azure deployment names.
# Leave empty to use matching deployment names for all supported models.
# Example:
# AZURE_MODEL_DEPLOYMENTS={"gpt-5.4":"my-prod-gpt54","gpt-5.4-mini":"team-mini"}
AZURE_MODEL_DEPLOYMENTS=

# Optional Azure settings
AZURE_SUMMARY_LEVEL=
AZURE_VERBOSITY_LEVEL=
AZURE_TRUNCATION=

# Optional Codex provider settings. Enable Codex only after `conduit auth login`.
CODEX_AUTH_PATH=~/.conduit/auth.json
CODEX_RESPONSES_URL=https://chatgpt.com/backend-api/codex/responses
CODEX_SUPPORTED_MODELS=gpt-5.5,gpt-5.4,gpt-5.4-mini,gpt-5.3-codex,gpt-5.3-codex-spark
CODEX_MODEL_REWRITES=
CODEX_MODEL_PROFILES=cp-gpt55-fast:gpt-5.5:low:priority,cp-gpt55-balanced:gpt-5.5:medium,cp-gpt55-high:gpt-5.5:high,cp-gpt55-xhigh:gpt-5.5:xhigh,cp-gpt55-xfast:gpt-5.5:xhigh:priority
CODEX_ORIGINATOR=conduit
CODEX_USER_AGENT="conduit/0.1.0"
# Set true if Cursor omits conversation markers on some requests (see README Troubleshooting).
CODEX_DISCOVERY_MODE=false
CODEX_TOKEN_REFRESH_SKEW_SECONDS=300
CODEX_REQUEST_TIMEOUT_SECONDS=600

# Optional Anthropic provider settings. Enable Anthropic after `conduit auth login --provider anthropic`.
ENABLE_ANTHROPIC=false
ANTHROPIC_AUTH_PATH=~/.conduit/anthropic_auth.json
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_VERSION=2023-06-01
ANTHROPIC_SUPPORTED_MODELS=claude-opus-4-8,claude-sonnet-4-6
ANTHROPIC_MODEL_PROFILES=cp-opus48-high:claude-opus-4-8:high:32768,cp-opus48-xhigh:claude-opus-4-8:xhigh:65536,cp-opus48-ultra:claude-opus-4-8:xhigh:65536,cp-opus48-max:claude-opus-4-8:max:65536,cp-opus48-xfast:claude-opus-4-8:xhigh:65536:fast
ANTHROPIC_CACHE_CONTROL=auto
ANTHROPIC_CACHE_TTL=5m
ANTHROPIC_THINKING_DISPLAY=summarized
ANTHROPIC_EAGER_TOOL_STREAMING=true
ANTHROPIC_CLAUDE_CODE_VERSION=2.1.75
ANTHROPIC_TOKEN_REFRESH_SKEW_SECONDS=300
ANTHROPIC_REQUEST_TIMEOUT_SECONDS=600

# Optional Fusion-style compound aliases on the OpenAI-compatible /codex route.
# The default examples include Claude panel models, so enable Anthropic auth if you use them.
# Format: alias:synthesizer:panel1|panel2
FUSION_MODEL_PROFILES=cp-fusion55:cp-opus48-xhigh:cp-gpt55-xhigh|cp-opus48-xhigh,cp-fusion55-fast:cp-gpt55-fast:cp-gpt55-balanced|cp-opus48-high
FUSION_PANEL_MAX_TOKENS=2048
FUSION_PANEL_TIMEOUT_SECONDS=180
